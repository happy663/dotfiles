{
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "0",
    "DISABLE_COST_WARNINGS": "1",
    "BASH_DEFAULT_TIMEOUT_MS": "9600000",
    "BASH_MAX_TIMEOUT_MS": "9600000"
  },
  "permissions": {
    "allow": [
      "List(*)",
      "Fetch(https://*)",
      "Read(*)",
      "Grep(*)",
      "Read(~/.zshrc)",
      "Read(~/src/github.com/**)",
      "Read(~/dotfiles/**)",
      "Read($(ghq root)/**)",
      "Bash(ls:*)",
      "Bash(rg:*)",
      "Bash(mv:*)",
      "Bash(cp:*)",
      "Bash(cat:*)",
      "Bash(find:*)",
      "Bash(terminal-notifier:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git pull:*)",
      "Bash(git fetch:*)",
      "Bash(git checkout:*)",
      "Bash(git stash:*)",
      "Bash(gh auth status:*)",
      "Bash(gh repo view:*)",
      "Bash(gh repo list:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr status:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh issue list:*)",
      "Bash(gh issue view:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(gh browse:*)",
      "Bash(gh config list:*)",
      "Bash(gh api:*)",
      "Bash(gh release list:*)",
      "Bash(gh release view:*)",
      "Bash(ghq list:*)",
      "Bash(ghq root:*)",
      "Bash(cd:*)",
      "Bash(echo:*)",
      "Bash(date:*)",
      "Bash(hostname:*)",
      "Bash(vm_stat:*)",
      "Bash(basename:*)",
      "Bash(dirname:*)",
      "Bash(wc:*)",
      "Bash(tr:*)",
      "Bash(awk:*)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(xargs:*)",
      "mcp__serena__search_for_pattern",
      "mcp__serena__list_dir",
      "mcp__serena__find_file",
      "mcp__serena__find_symbol",
      "mcp__serena__replace_regex",
      "Bash(rustc --version)",
      "Bash(rustup toolchain:*)",
      "Bash(cargo clean:*)",
      "Bash(cargo build:*)",
      "Bash(cargo --version)",
      "Bash(brew list:*)",
      "Bash(mise list:*)",
      "Bash(mise plugin:*)",
      "Bash(mise use:*)",
      "Bash(mise exec rust@nightly:*)",
      "Bash(mise bin-paths:*)",
      "Bash(nvim:*)",
      "Bash(npx ccusage:*)",
      "Bash(fd:*)",
      "Bash(mkdir:*)",
      "Bash(ghq get:*)",
      "Bash(git clone:*)",
      "Bash(git describe:*)",
      "Bash(vim:*)",
      "Bash(zsh:*)",
      "Bash(exec zsh -l)",
      "Bash(stty:*)",
      "Bash(mdfind:*)",
      "Bash(infocmp:*)",
      "Bash(tmux list-sessions:*)",
      "Bash(tmux show-environment:*)",
      "Bash(tmux show-options:*)",
      "Bash(tmux show:*)",
      "Bash(ghostty:*)",
      "Bash(lazygit:*)",
      "Bash(mise ls-remote:*)",
      "Bash(npm install:*)",
      "Bash(gh search:*)",
      "Bash(sed:*)",
      "WebSearch"
    ],
    "deny": ["Bash(rm:*)"],
    "defaultMode": "default"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/scripts/pipe-stage-permissions.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.config/tmux/plugins/tmux-agent-sidebar/hook.sh claude session-start"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.config/tmux/plugins/tmux-agent-sidebar/hook.sh claude session-end"
          },
          {
            "type": "command",
            "command": "bash ~/.config/tmux/scripts/agent-window-status.sh idle"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.config/tmux/plugins/tmux-agent-sidebar/hook.sh claude user-prompt-submit"
          },
          {
            "type": "command",
            "command": "bash ~/.config/tmux/scripts/agent-window-status.sh running"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"Claude Code: $(jq -r '.tool_name')\" | terminal-notifier -title 'Claude Code' -sound 'Blow'"
          },
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path | select(endswith(\".lua\"))' | xargs -r stylua"
          },
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path | select(endswith(\".json\"))' | xargs -r npx prettier --write "
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.config/tmux/plugins/tmux-agent-sidebar/hook.sh claude activity-log"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo \"Claude Code: $(jq -r '.hook_event_name')\" | terminal-notifier -title 'Claude Code' -sound 'Blow'"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.config/tmux/plugins/tmux-agent-sidebar/hook.sh claude stop"
          },
          {
            "type": "command",
            "command": "bash ~/.config/tmux/scripts/agent-window-status.sh done"
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.config/tmux/plugins/tmux-agent-sidebar/hook.sh claude stop-failure"
          },
          {
            "type": "command",
            "command": "bash ~/.config/tmux/scripts/agent-window-status.sh error"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo \"Claude Code: $(jq -r '.message')\" | terminal-notifier -title 'Claude Code'"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.config/tmux/plugins/tmux-agent-sidebar/hook.sh claude notification"
          },
          {
            "type": "command",
            "command": "bash ~/.config/tmux/scripts/agent-window-status.sh waiting"
          }
        ]
      }
    ],
    "PermissionDenied": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.config/tmux/plugins/tmux-agent-sidebar/hook.sh claude permission-denied"
          }
        ]
      }
    ],
    "CwdChanged": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.config/tmux/plugins/tmux-agent-sidebar/hook.sh claude cwd-changed"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.config/tmux/plugins/tmux-agent-sidebar/hook.sh claude subagent-start"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.config/tmux/plugins/tmux-agent-sidebar/hook.sh claude subagent-stop"
          }
        ]
      }
    ],
    "TaskCreated": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.config/tmux/plugins/tmux-agent-sidebar/hook.sh claude task-created"
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.config/tmux/plugins/tmux-agent-sidebar/hook.sh claude task-completed"
          }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.config/tmux/plugins/tmux-agent-sidebar/hook.sh claude teammate-idle"
          }
        ]
      }
    ],
    "WorktreeCreate": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.config/tmux/plugins/tmux-agent-sidebar/hook.sh claude worktree-create"
          }
        ]
      }
    ],
    "WorktreeRemove": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.config/tmux/plugins/tmux-agent-sidebar/hook.sh claude worktree-remove"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-script.sh"
  },
  "enabledPlugins": {
    "permissions-audit@makikub-plugins": true
  },
  "extraKnownMarketplaces": {
    "makikub-plugins": {
      "source": {
        "source": "git",
        "url": "https://github.com/makikub/claude-code-plugin.git"
      }
    }
  },
  "effortLevel": "medium",
  "plansDirectory": "./plans",
  "skipAutoPermissionPrompt": true
}
